# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/legacy

# Redis URL (used for refresh token storage)
REDIS_URL=redis://127.0.0.1:6379

# JWT signing secret — change this to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret

# Access token lifetime in seconds (default: 15 min)
ACCESS_TOKEN_EXPIRY_SECS=900

# Refresh token lifetime in seconds (default: 7 days)
REFRESH_TOKEN_EXPIRY_SECS=604800

# Frontend origin for CORS (no trailing slash)
FRONTEND_URL=http://localhost:5173

# One-time setup account — set ENABLED=true to seed an admin user on first boot
# Disable again after first login!
SETUP_ACCOUNT_ENABLED=false
SETUP_ACCOUNT_EMAIL=admin@legacy.local
SETUP_ACCOUNT_PASSWORD=change_me_on_first_boot
